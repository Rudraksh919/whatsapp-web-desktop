{
  "name": "whatsapp-web-desktop",
  "version": "1.0.2",
  "description": "Desktop wrapper for WhatsApp Web (unofficial)",
  "main": "main.js",
  "author": {
    "name": "Rudraksh",
    "email": "rudrakshkumawat919@gmail.com"
  },
  "homepage": "https://github.com/Rudraksh919/whatsapp-web-desktop",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.whatsapp.web.desktop",
    "productName": "WhatsApp Web Desktop",
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Network",
      "icon": "assets"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhatsApp Web",
      "uninstallDisplayName": "WhatsApp Web Desktop"
    }
  },
  "devDependencies": {
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "node-notifier": "^10.0.1"
  }
}

{
  "name": "whatsapp-web-desktop",
  "version": "1.0.4",
  "description": "Desktop wrapper for WhatsApp Web",
  "main": "main.js",
  "author": {
    "name": "Rudraksh Kumawat",
    "email": "rudrakshkumawat919@gmail.com"
  },
  "homepage": "https://github.com/Rudraksh919/whatsapp-web-desktop",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.whatsapp.web.desktop",
    "productName": "WhatsApp Web Desktop",
    "protocols": [
      {
        "name": "WhatsApp Web Desktop",
        "schemes": [
          "whatsapp-webapp"
        ]
      }
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64", "ia32", "arm64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64", "ia32", "arm64"]
        }
      ],
      "category": "Network",
      "icon": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32", "arm64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "artifactName": "${name}-${version}-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhatsApp Web",
      "uninstallDisplayName": "WhatsApp Web Desktop"
    }
  },
  "devDependencies": {
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "node-notifier": "^10.0.1"
  }
}
